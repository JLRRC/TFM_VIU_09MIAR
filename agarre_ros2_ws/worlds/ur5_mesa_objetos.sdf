          <material><diffuse>0.35 0.35 0.35 1</diffuse></material>
        </visual>

        <collision name="wall_south_c">
          <pose>0 -0.39 0.785 0 0 0</pose>
          <geometry><box><size>0.728 0.02 0.02</size></box></geometry>
        </collision>
