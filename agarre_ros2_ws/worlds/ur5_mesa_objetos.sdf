    <include>
      <uri>model://ur5_rg2</uri>
      <name>ur5_rg2</name>
      
      <pose>-0.85 0.00 0.775 0 0 0</pose>
      
    </include>
    <joint name="ur5_rg2_fixed_to_world" type="fixed">
      <parent>world</parent>
      <pose>-0.85 0.00 0.775 0 0 0</pose>
      <child>ur5_rg2::base_link</child>
    </joint>

    

    
    <model name="camera_overhead">
      <static>true</static>
      <pose>-0.85 0.00 1.85 0 1.02 0</pose>
      <link name="link">
        <sensor name="camera_overhead_rgb" type="camera">
          <always_on>true</always_on>
          <update_rate>30</update_rate>
          <topic>/camera_overhead/image</topic>
          <camera>
            <horizontal_fov>0.75</horizontal_fov>
            <image><width>320</width><height>240</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>10.0</far></clip>
          </camera>
        </sensor>
        <sensor name="camera_overhead_depth" type="depth_camera">
          <always_on>true</always_on>
          <update_rate>30</update_rate>
          <topic>/camera_overhead/depth_image</topic>
          <camera>
            <horizontal_fov>0.75</horizontal_fov>
            <image><width>320</width><height>240</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>10.0</far></clip>
          </camera>
        </sensor>
      </link>
    </model>

    
    
    

    <model name="camera_north">
